SAFEPLATE_USER_AGENT="SafePlate student project <your-email@example.com>"
GEOAPIFY_API_KEY="your-geoapify-api-key"
GOOGLE_PLACES_API_KEY="your-google-places-api-key"
BRAVE_SEARCH_API_KEY="your-brave-search-api-key"

# Optional tuning (defaults shown). Brave queries are governed by a shared token
# bucket (rate) + semaphore (in-flight). Defaults target ~80% of a 50 req/s plan.
# SAFEPLATE_BRAVE_RPS=40
# SAFEPLATE_BRAVE_CONCURRENCY=20
# SAFEPLATE_GEMINI_CONCURRENCY=12
